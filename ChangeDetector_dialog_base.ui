  <property name="styleSheet">
   <string notr="true">
QDialog {
    background-color: #f2f5f9;
    font-family: Segoe UI;
    font-size: 10pt;
    color: #2f3b45;
}

/* =========================
   GROUP BOXES
========================= */
QGroupBox {
    background-color: #ffffff;
    border: 1px solid #cfd8e3;
    border-radius: 10px;
    margin-top: 10px;
    padding-top: 12px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 6px;
    color: #1f4e79;
}

/* =========================
   LABELS
========================= */
QLabel {
    color: #34495e;
    background: transparent;
}

/* =========================
   INPUT FIELDS
========================= */
QLineEdit {
    background-color: white;
    border: 1px solid #b7c4cf;
    border-radius: 6px;
    padding: 4px;
}

QLineEdit:focus {
    border: 1px solid #4a90e2;
}

/* =========================
   COMBOBOX
========================= */
QComboBox {
    background-color: white;
    border: 1px solid #b7c4cf;
    border-radius: 6px;
    padding: 4px;
}

QComboBox:focus {
    border: 1px solid #4a90e2;
}

/* =========================
   SPINBOX
========================= */
QSpinBox, QDoubleSpinBox {
    background-color: white;
    border: 1px solid #b7c4cf;
    border-radius: 6px;
    padding: 3px;
}

/* =========================
   CHECKBOX
========================= */
QCheckBox {
    spacing: 5px;
    color: #2f3b45;
}

/* =========================
   PUSH BUTTONS
========================= */
QPushButton {
    background-color: #4a90e2;
    color: white;
    border-radius: 7px;
    padding: 5px 10px;
    font-weight: bold;
    border: none;
}

QPushButton:hover {
    background-color: #357abd;
}

/* OK button */
QPushButton#okButton {
    background-color: #27ae60;
}

QPushButton#okButton:hover {
    background-color: #219150;
}

/* Cancel button */
QPushButton#cancelButton {
    background-color: #e74c3c;
}

QPushButton#cancelButton:hover {
    background-color: #c0392b;
}

/* =========================
   PREVIEW AREAS
========================= */
QScrollArea {
    background-color: white;
    border: 1px solid #cfd8e3;
    border-radius: 8px;
}

/* =========================
   PROGRESS BAR
========================= */
QProgressBar {
    background-color: white;
    border: 1px solid #cfd8e3;
    border-radius: 6px;
    text-align: center;
    min-height: 20px;
}

QProgressBar::chunk {
    background-color: #4a90e2;
    border-radius: 5px;
}

</string>
